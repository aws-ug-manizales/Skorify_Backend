{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "jest"],
    "module": "commonjs",
    "moduleResolution": "node"
    ,"baseUrl": ".",
    "paths": {
      "@skorify/domain": ["../domain/src/index.ts"],
      "@skorify/domain/*": ["../domain/src/features/*"],
      "@skorify/domain/core": ["../domain/src/core/index.ts"],
      "@skorify/shared": ["../shared/src/index.ts"],
      "@skorify/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "../domain/src/**/*.ts", "../shared/src/**/*.ts"]
}
