{
  "compilerOptions": {
    "baseUrl": "./",
    "rootDir": "./",
    "module": "nodenext",
    "types": ["node"],
    "noImplicitReturns": false,
    "noUnusedLocals": false,
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true
  },
  "compileOnSave": true,

  "include": ["src", "src/index.ts", "../domain/src/features/**.*"],
  "exclude": ["src/**/*.test.ts"]
}
