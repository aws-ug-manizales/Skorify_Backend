{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "jest"],
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@skorify/domain/core": ["node_modules/@skorify/domain/core/index.d.ts"],
      "@skorify/domain/match": ["node_modules/@skorify/domain/features/match/index.d.ts"],
      "@skorify/domain/team": ["node_modules/@skorify/domain/features/team/index.d.ts"],
      "@skorify/domain/user": ["node_modules/@skorify/domain/features/user/index.d.ts"],
      "@skorify/domain/prediction": ["node_modules/@skorify/domain/features/prediction/index.d.ts"],
      "@skorify/domain/tournament": ["node_modules/@skorify/domain/features/tournament/index.d.ts"],
      "@skorify/domain/tournament-instance": ["node_modules/@skorify/domain/features/tournament-instance/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
